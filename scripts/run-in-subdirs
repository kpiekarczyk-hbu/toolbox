#!/usr/bin/env bash
# Run a command in every visible subdirectory of the current working directory.
# Stops on first error by default; pass -c/--continue to keep going.

set -u
set -o pipefail

__lib="$(dirname -- "${BASH_SOURCE[0]}")/.lib/common.sh"
. "$__lib" || { echo "fatal: cannot source $__lib" >&2; exit 1; }

usage() {
  cat <<EOF
Usage: run-in-subdirs [options] <command>

Runs <command> in each visible subdirectory of the current working directory.

Options:
  -c, --continue
                Continue iterating even if the command fails in a subdir.
                Without this flag, the script stops on the first error.
$(filter_options_help)
  -h, --help    Show this help and exit.

The command is a single string evaluated by the shell, so pipes,
redirects, and && work as expected:

  run-in-subdirs 'git pull && npm install'
EOF
}

continue_on_error=0
while (( $# > 0 )); do
  case "$1" in
    -c|--continue) continue_on_error=1; shift ;;
    -i|--include)  [[ $# -lt 2 ]] && { err "$1 requires an argument"; exit 2; }
                   filter_add_include "$2"; shift 2 ;;
    -x|--exclude)  [[ $# -lt 2 ]] && { err "$1 requires an argument"; exit 2; }
                   filter_add_exclude "$2"; shift 2 ;;
    -h|--help)     usage; exit 0 ;;
    --)            shift; break ;;
    -*)            err "unknown option: $1"; usage >&2; exit 2 ;;
    *)             break ;;
  esac
done

if (( $# < 1 )); then
  err "missing command"
  usage >&2
  exit 2
fi

cmd="$*"

collect_filtered_subdirs

if (( ${#subdirs[@]} == 0 )); then
  info "No subdirectories matched in $PWD"
  exit 0
fi

total=${#subdirs[@]}
succeeded=0
failed=0
failed_dirs=()
i=0

for dir in "${subdirs[@]}"; do
  (( i++ ))

  step "[$i/$total] Running \"$cmd\" in \"$dir\""

  ( cd "$dir" && eval "$cmd" )
  rc=$?

  if (( rc == 0 )); then
    (( succeeded++ ))
    printf '%s    ok%s\n' "$c_green" "$c_reset"
  else
    (( failed++ ))
    failed_dirs+=( "$dir" )
    err "command failed in \"$dir\" (exit $rc)"
    if (( continue_on_error == 0 )); then
      err "stopping; re-run with -c to continue past failures"
      exit "$rc"
    fi
  fi
done

printf '\n%sDone.%s %d succeeded, %d failed (of %d).\n' \
  "$c_dim" "$c_reset" "$succeeded" "$failed" "$total"

if (( failed > 0 )); then
  printf '%sFailed in:%s %s\n' "$c_red" "$c_reset" "${failed_dirs[*]}" >&2
  exit 1
fi
